{
  "name": "@sema-lang/opencode-sema",
  "description": "OpenCode plugin for Sema — LSP, MCP, and theme",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "author": "Helge Sverre <helge.sverre@gmail.com>",
  "homepage": "https://sema-lang.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sema-lisp/opencode-sema.git"
  },
  "bugs": {
    "url": "https://github.com/sema-lisp/opencode-sema/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./theme": "./themes/sema.json"
  },
  "files": [
    "dist",
    "themes",
    "scripts",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "node scripts/postinstall.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "sema",
    "sema-lang",
    "lisp",
    "lsp",
    "mcp"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.18.2",
    "@types/node": "^26.1.1",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  }
}
